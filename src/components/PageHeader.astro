---
import EcgTrace from "./EcgTrace.astro";

interface Props {
  eyebrow: string;
  title: string;
  lede?: string;
}
const { eyebrow, title, lede } = Astro.props;
---

<div class="wrap page-header">
  <p class="eyebrow">{eyebrow}</p>
  <h1>{title}</h1>
  {lede && <p class="lede measure muted">{lede}</p>}
  <EcgTrace class="header-trace" />
</div>

<style>
  .page-header {
    padding-block: 2.6rem 0.5rem;
  }

  .lede {
    font-size: 1.12rem;
    margin-top: 0.4rem;
  }

  :global(.header-trace) {
    margin-top: 0.8rem;
    max-width: 320px;
    opacity: 0.85;
  }
</style>
